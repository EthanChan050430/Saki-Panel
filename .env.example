PANEL_PORT=5479
PANEL_HOST=0.0.0.0
PANEL_PUBLIC_URL=http://localhost:5479
WEB_ORIGIN=http://localhost:5478
PANEL_CORS_ORIGINS=*
VITE_HOST=0.0.0.0
VITE_ALLOWED_HOSTS=*
VITE_API_BASE_URL=
DATABASE_URL=file:../data/panel/dev.db
JWT_SECRET=change-me-before-production
DISABLE_AUTH=0
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123456
DAEMON_REGISTRATION_TOKEN=dev-registration-token

DAEMON_PORT=24444
DAEMON_HOST=127.0.0.1
DAEMON_NAME=Local Daemon
DAEMON_PANEL_URL=http://localhost:5479
DAEMON_PROTOCOL=http
DAEMON_HEARTBEAT_SECONDS=10

# Backend logging: warn keeps routine request/heartbeat logs out of the terminal.
# Set LOG_LEVEL=info or debug when you need detailed request logs.
LOG_LEVEL=warn

# Optional Saki copilot defaults. Panel calls the configured model provider directly.
# SAKI_PROVIDER=ollama
# SAKI_MODEL=llama3
# SAKI_OLLAMA_URL=http://localhost:11434
# SAKI_REQUEST_TIMEOUT_MS=120000
